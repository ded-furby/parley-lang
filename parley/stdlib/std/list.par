to all_yes with xs as list of yesno giving yesno:
    for each value in xs:
        if value is no:
            give back no
    give back yes

to any_yes with xs as list of yesno giving yesno:
    for each value in xs:
        if value:
            give back yes
    give back no

to maybe_item_yesno with xs as list of yesno, index as number giving maybe yesno:
    if index is less than 1 or index is more than length of xs:
        give back nothing
    give back some item index of xs

to list_slice_yesno with xs as list of yesno, first_index as number, last_index as number giving list of yesno:
    let out be an empty list of yesno
    if length of xs is 0:
        give back out
    if first_index is more than last_index:
        give back out
    if last_index is less than 1:
        give back out
    if first_index is more than length of xs:
        give back out
    let start be first_index
    if start is less than 1:
        set start to 1
    let finish be last_index
    if finish is more than length of xs:
        set finish to length of xs
    for each i from start to finish:
        let value be item i of xs
        add value to out
    give back out

to extend_yesno with changing xs as list of yesno, more as list of yesno:
    for each value in more:
        add value to xs

to clear_yesno with changing xs as list of yesno:
    while length of xs is more than 0:
        remove item 1 of xs

to count_yes with xs as list of yesno giving number:
    let count be 0
    for each value in xs:
        if value:
            set count to count plus 1
    give back count

to count_no with xs as list of yesno giving number:
    let count be 0
    for each value in xs:
        if value is no:
            set count to count plus 1
    give back count

to index_yes with xs as list of yesno giving maybe number:
    let index be 1
    for each value in xs:
        if value:
            give back some index
        set index to index plus 1
    give back nothing

to index_no with xs as list of yesno giving maybe number:
    let index be 1
    for each value in xs:
        if value is no:
            give back some index
        set index to index plus 1
    give back nothing
