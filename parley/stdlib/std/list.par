to first_number with xs as list of number giving number:
    give back item 1 of xs

to last_number with xs as list of number giving number:
    give back item (length of xs) of xs

to maybe_first_number with xs as list of number giving maybe number:
    if length of xs is 0:
        give back nothing
    give back some item 1 of xs

to maybe_last_number with xs as list of number giving maybe number:
    if length of xs is 0:
        give back nothing
    give back some item (length of xs) of xs

to maybe_item_number with xs as list of number, index as number giving maybe number:
    if index is less than 1 or index is more than length of xs:
        give back nothing
    give back some item index of xs

to list_slice_number with xs as list of number, first_index as number, last_index as number giving list of number:
    let out be an empty list of number
    if length of xs is 0:
        give back out
    if first_index is more than last_index:
        give back out
    if last_index is less than 1:
        give back out
    if first_index is more than length of xs:
        give back out
    let start be first_index
    if start is less than 1:
        set start to 1
    let finish be last_index
    if finish is more than length of xs:
        set finish to length of xs
    for each i from start to finish:
        let value be item i of xs
        add value to out
    give back out

to extend_number with changing xs as list of number, more as list of number:
    for each value in more:
        add value to xs

to clear_number with changing xs as list of number:
    while length of xs is more than 0:
        remove item 1 of xs

to count_number with xs as list of number, needle as number giving number:
    let count be 0
    for each value in xs:
        if value is needle:
            set count to count plus 1
    give back count

to index_number with xs as list of number, needle as number giving maybe number:
    let index be 1
    for each value in xs:
        if value is needle:
            give back some index
        set index to index plus 1
    give back nothing

to average_number with xs as list of number giving decimal:
    give back (decimal from (sum of xs)) divided by (decimal from (length of xs))

to maybe_smallest_number with xs as list of number giving maybe number:
    if length of xs is 0:
        give back nothing
    let value be smallest of xs
    give back some value

to maybe_largest_number with xs as list of number giving maybe number:
    if length of xs is 0:
        give back nothing
    let value be largest of xs
    give back some value

to maybe_average_number with xs as list of number giving maybe decimal:
    if length of xs is 0:
        give back nothing
    let value be (average_number with xs)
    give back some value

