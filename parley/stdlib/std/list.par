        give back nothing
    let value be (population_standard_deviation_decimal with xs)
    give back some value

to maybe_sample_variance_decimal with xs as list of decimal giving maybe decimal:
    if length of xs is less than 2:
        give back nothing
    let value be (sample_variance_decimal with xs)
    give back some value

to maybe_sample_standard_deviation_decimal with xs as list of decimal giving maybe decimal:
    if length of xs is less than 2:
        give back nothing
    let value be (sample_standard_deviation_decimal with xs)
    give back some value

to maybe_covariance_decimal with xs as list of decimal, ys as list of decimal giving maybe decimal:
    if length of xs is not length of ys:
        give back nothing
    if length of xs is less than 2:
        give back nothing
    let value be (covariance_decimal with xs, ys)
    give back some value

to maybe_correlation_decimal with xs as list of decimal, ys as list of decimal giving maybe decimal:
    if length of xs is not length of ys:
        give back nothing
    if length of xs is less than 2:
        give back nothing
    if (sample_variance_decimal with xs) is 0.0:
        give back nothing
    if (sample_variance_decimal with ys) is 0.0:
        give back nothing
    let value be (correlation_decimal with xs, ys)
    give back some value

to maybe_linear_regression_decimal with xs as list of decimal, ys as list of decimal giving maybe list of decimal:
    if length of xs is not length of ys:
        give back nothing
    if length of xs is less than 2:
        give back nothing
    if (sample_variance_decimal with xs) is 0.0:
        give back nothing
    let value be (linear_regression_decimal with xs, ys)
    give back some value

to maybe_proportional_linear_regression_decimal with xs as list of decimal, ys as list of decimal giving maybe list of decimal:
    if length of xs is not length of ys:
        give back nothing
    if length of xs is less than 2:
        give back nothing
    let x_total be 0.0
    for each value in xs:
        set x_total to x_total plus value times value
    if x_total is 0.0:
        give back nothing
    let value be (proportional_linear_regression_decimal with xs, ys)
    give back some value

to maybe_geometric_mean_decimal with xs as list of decimal giving maybe decimal:
    if length of xs is 0:
        give back nothing
    for each value in xs:
        if value is less than 0.0:
            give back nothing
    let value be (geometric_mean_decimal with xs)
    give back some value

to maybe_harmonic_mean_decimal with xs as list of decimal giving maybe decimal:
    if length of xs is 0:
        give back nothing
    for each value in xs:
        if value is less than 0.0:
            give back nothing
    let value be (harmonic_mean_decimal with xs)
    give back some value

to maybe_quantiles_decimal with xs as list of decimal, groups as number giving maybe list of decimal:
    if groups is less than 1:
        give back nothing
    if length of xs is 0:
        give back nothing
    let value be (quantiles_decimal with xs, groups)
    give back some value

to maybe_inclusive_quantiles_decimal with xs as list of decimal, groups as number giving maybe list of decimal:
    if groups is less than 1:
        give back nothing
    if length of xs is 0:
        give back nothing
    let value be (inclusive_quantiles_decimal with xs, groups)
    give back some value

to first_yesno with xs as list of yesno giving yesno:
    give back item 1 of xs

to last_yesno with xs as list of yesno giving yesno:
    give back item (length of xs) of xs

to maybe_first_yesno with xs as list of yesno giving maybe yesno:
    if length of xs is 0:
        give back nothing
    give back some item 1 of xs

to maybe_last_yesno with xs as list of yesno giving maybe yesno:
    if length of xs is 0:
        give back nothing
    give back some item (length of xs) of xs

to all_yes with xs as list of yesno giving yesno:
    for each value in xs:
        if value is no:
            give back no
    give back yes

to any_yes with xs as list of yesno giving yesno:
    for each value in xs:
        if value:
            give back yes
    give back no

to maybe_item_yesno with xs as list of yesno, index as number giving maybe yesno:
    if index is less than 1 or index is more than length of xs:
        give back nothing
    give back some item index of xs

to list_slice_yesno with xs as list of yesno, first_index as number, last_index as number giving list of yesno:
    let out be an empty list of yesno
    if length of xs is 0:
        give back out
    if first_index is more than last_index:
        give back out
    if last_index is less than 1:
        give back out
    if first_index is more than length of xs:
        give back out
    let start be first_index
    if start is less than 1:
        set start to 1
    let finish be last_index
    if finish is more than length of xs:
        set finish to length of xs
    for each i from start to finish:
        let value be item i of xs
        add value to out
    give back out

to copy_yesno with xs as list of yesno giving list of yesno:
    let out be an empty list of yesno
    for each value in xs:
        add value to out
    give back out

to filter_yesno with xs as list of yesno, keep as (function taking yesno giving yesno) giving list of yesno:
    let out be an empty list of yesno
    for each value in xs:
        if (keep with value):
            add value to out
    give back out

to reject_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving list of yesno:
    let out be an empty list of yesno
    for each value in xs:
        if (test with value) is no:
            add value to out
    give back out

to map_yesno with xs as list of yesno, transform as (function taking yesno giving yesno) giving list of yesno:
    let out be an empty list of yesno
    for each value in xs:
        add (transform with value) to out
    give back out

to fold_yesno with xs as list of yesno, initial as yesno, combine as (function taking yesno, yesno giving yesno) giving yesno:
    let out be initial
    for each value in xs:
        set out to (combine with out, value)
    give back out

to any_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving yesno:
    for each value in xs:
        if (test with value):
            give back yes
    give back no

to all_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving yesno:
    for each value in xs:
        if (test with value) is no:
            give back no
    give back yes

to maybe_find_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving maybe yesno:
    for each value in xs:
        if (test with value):
            give back some value
    give back nothing

to maybe_find_index_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving maybe number:
    let spot be 1
    for each value in xs:
        if (test with value):
            give back some spot
        set spot to spot plus 1
    give back nothing

to indexes_where_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving list of number:
    let out be an empty list of number
    let spot be 1
    for each value in xs:
        if (test with value):
            add spot to out
        set spot to spot plus 1
    give back out

to count_where_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving number:
    let count be 0
    for each value in xs:
        if (test with value):
            set count to count plus 1
    give back count

to take_while_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving list of yesno:
    let out be an empty list of yesno
    for each value in xs:
        if (test with value):
            add value to out
        otherwise:
            stop
    give back out

to drop_while_yesno with xs as list of yesno, test as (function taking yesno giving yesno) giving list of yesno:
    let out be an empty list of yesno
    let dropping be yes
    for each value in xs:
        if dropping:
            if (test with value):
                skip
            set dropping to no
        add value to out
    give back out

to extend_yesno with changing xs as list of yesno, more as list of yesno:
    for each value in more:
        add value to xs

to clear_yesno with changing xs as list of yesno:
    while length of xs is more than 0:
        remove item 1 of xs

to insert_yesno with changing xs as list of yesno, index as number, value as yesno:
    let out be an empty list of yesno
    let placed be no
    if index is at most 1:
        add value to out
        set placed to yes
    let spot be 1
    for each current in xs:
        if placed is no and spot is at least index:
            add value to out
            set placed to yes
        add current to out
        set spot to spot plus 1
    if placed is no:
        add value to out
    clear_yesno with xs
    extend_yesno with xs, out

to pop_yesno with changing xs as list of yesno, index as number giving maybe yesno:
    if index is less than 1 or index is more than length of xs:
        give back nothing
    let value be item index of xs
    remove item index of xs
    give back some value

to remove_yesno with changing xs as list of yesno, value as yesno giving yesno:
    let spot be 1
    for each current in xs:
        if current is value:
            remove item spot of xs
            give back yes
        set spot to spot plus 1
    give back no

to reverse_yesno with changing xs as list of yesno:
    let out be an empty list of yesno
    let index be length of xs
    while index is at least 1:
        add item index of xs to out
        set index to index minus 1
    clear_yesno with xs
    extend_yesno with xs, out

to sort_yesno with changing xs as list of yesno:
    let no_count be 0
    let yes_count be 0
    for each value in xs:
        if value:
            set yes_count to yes_count plus 1
        otherwise:
            set no_count to no_count plus 1
    clear_yesno with xs
    repeat no_count times:
        add no to xs
    repeat yes_count times:
        add yes to xs

to count_yes with xs as list of yesno giving number:
    let count be 0
    for each value in xs:
        if value:
            set count to count plus 1
    give back count

to count_no with xs as list of yesno giving number:
    let count be 0
    for each value in xs:
        if value is no:
            set count to count plus 1
    give back count

to count_yesno with xs as list of yesno, needle as yesno giving number:
    let count be 0
    for each value in xs:
        if value is needle:
            set count to count plus 1
    give back count

to mode_yesno with xs as list of yesno giving yesno:
    if length of xs is 0:
        fail "mode_yesno needs at least one item"
    let best be item 1 of xs
    let best_count be 0
    for each value in xs:
        let value_count be (count_yesno with xs, value)
        if value_count is more than best_count:
            set best to value
            set best_count to value_count
    give back best

to modes_yesno with xs as list of yesno giving list of yesno:
    let out be an empty list of yesno
    let best_count be 0
    for each value in xs:
        let value_count be (count_yesno with xs, value)
        if value_count is more than best_count:
            clear_yesno with out
            add value to out
            set best_count to value_count
        otherwise if value_count is best_count and (contains_yesno with out, value) is no:
            add value to out
    give back out

to contains_yesno with xs as list of yesno, needle as yesno giving yesno:
    for each value in xs:
        if value is needle:
            give back yes
    give back no

to index_yes with xs as list of yesno giving maybe number:
    let index be 1
    for each value in xs:
        if value:
            give back some index
        set index to index plus 1
    give back nothing

to index_no with xs as list of yesno giving maybe number:
    let index be 1
    for each value in xs:
        if value is no:
            give back some index
        set index to index plus 1
    give back nothing

to index_yesno with xs as list of yesno, needle as yesno giving maybe number:
    let index be 1
    for each value in xs:
        if value is needle:
            give back some index
        set index to index plus 1
    give back nothing

to maybe_mode_yesno with xs as list of yesno giving maybe yesno:
    if length of xs is 0:
        give back nothing
    let value be (mode_yesno with xs)
    give back some value
